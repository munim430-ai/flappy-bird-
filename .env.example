# SecurityTrails API key — get one free at https://securitytrails.com/app/account
# If omitted, passive_dns falls back to plain DNS resolution via dnspython.
SECURITYTRAILS_API_KEY=

# urlscan.io API key — get one free at https://urlscan.io/user/signup
# Required for urlscan_client; without it the module skips urlscan queries.
URLSCAN_API_KEY=
